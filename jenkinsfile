pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/YOUR_USERNAME/ai-chatbot.git'
            }
        }

        stage('Install Backend Dependencies') {
            steps {
                dir('backend') {
                    bat 'npm install'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('backend') {
                    bat 'docker build -t ai-chatbot-backend .'
                }
            }
        }

        stage('Run Container') {
            steps {
                bat 'docker rm -f ai-chatbot-container || exit 0'
                bat 'docker run -d -p 5000:5000 --name ai-chatbot-container --env-file backend/.env ai-chatbot-backend'
            }
        }
    }
}